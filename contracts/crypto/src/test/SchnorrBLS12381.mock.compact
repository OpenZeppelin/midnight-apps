// OpenZeppelin Midnight Apps Contracts v0.0.1-alpha.0 (crypto/test/SchnorrBLS12381.mock.compact)

pragma language_version >= 0.18.0;

import CompactStandardLibrary;

import "../interfaces/ISchnorrBLS12318";
import "../SchnorrBLS12381" prefix Schnorr_;

export { SchnorrSignature, SchnorrKeyPair };

export ledger steps: Counter;

export circuit derivePublicKey(sk: Bytes<32>): CurvePoint {
  steps.increment(1);
  return Schnorr_derivePublicKey(sk);
}

export circuit generateKeyPair(sk: Bytes<32>): SchnorrKeyPair {
  steps.increment(1);
  return Schnorr_generateKeyPair(sk);
}

export circuit sign(sk: Bytes<32>, message: Bytes<32>, nonce: Bytes<32>): SchnorrSignature {
  steps.increment(1);
  return Schnorr_sign(sk, message, nonce);
}

export circuit verifySignature(
  publicKey: CurvePoint,
  message: Bytes<32>,
  signature: SchnorrSignature
): Boolean {
  steps.increment(1);
  return disclose(Schnorr_verifySignature(publicKey, message, signature));
}

export circuit isValidPublicKey(publicKey: CurvePoint): Boolean {
  steps.increment(1);
  return disclose(Schnorr_isValidPublicKey(publicKey));
}
